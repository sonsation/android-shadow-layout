<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Sticky Top Preview Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/preview_container"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:elevation="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_theme_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:padding="8dp"
            android:background="?selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_month"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#666666" />

        <com.sonsation.library.ShadowLayout
            android:id="@+id/shadow_layout"
            android:layout_width="160dp"
            android:layout_height="160dp"
            app:clipToOutline="true"
            app:background_color="#00000000"
            app:background_radius="32dp"
            app:shadow_blur="15dp"
            app:shadow_offset_y="5dp"
            app:shadow_color="#33000000"
            app:shadow_render_mode="BITMAP_CACHE"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Shadow"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

        </com.sonsation.library.ShadowLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Controls Area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/preview_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Colors Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎨 Colors"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <com.sonsation.library.ShadowLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:background_color="#FFFFFF"
                app:background_radius="16dp"
                app:shadow_blur="10dp"
                app:shadow_offset_y="2dp"
                app:shadow_color="#11000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include layout="@layout/item_color_picker" android:id="@+id/color_bg" />
                    <include layout="@layout/item_color_picker" android:id="@+id/color_shadow" />
                    <include layout="@layout/item_color_picker" android:id="@+id/color_stroke" />
                    <include layout="@layout/item_color_picker" android:id="@+id/color_content" />

                </LinearLayout>
            </com.sonsation.library.ShadowLayout>

            <!-- Shadow Geometry Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📐 Shadow Geometry"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <com.sonsation.library.ShadowLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:background_color="#FFFFFF"
                app:background_radius="16dp"
                app:shadow_blur="10dp"
                app:shadow_offset_y="2dp"
                app:shadow_color="#11000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <include layout="@layout/item_slider" android:id="@+id/slider_shadow_x" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_shadow_y" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_shadow_radius" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_shadow_spread" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_shadow_bitmap_resolution" />

                </LinearLayout>
            </com.sonsation.library.ShadowLayout>

            <!-- Shape Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟦 Shape"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <com.sonsation.library.ShadowLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:background_color="#FFFFFF"
                app:background_radius="16dp"
                app:shadow_blur="10dp"
                app:shadow_offset_y="2dp"
                app:shadow_color="#11000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <include layout="@layout/item_slider" android:id="@+id/slider_corner_radius" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_corner_smoothing" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_alpha" />

                </LinearLayout>
            </com.sonsation.library.ShadowLayout>

            <!-- Stroke Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🖌 Stroke"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <com.sonsation.library.ShadowLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:background_color="#FFFFFF"
                app:background_radius="16dp"
                app:shadow_blur="10dp"
                app:shadow_offset_y="2dp"
                app:shadow_color="#11000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_width" />
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">
                        
                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Stroke Type"
                            android:textSize="14sp"
                            android:textColor="#333333" />
                            
                        <RadioGroup
                            android:id="@+id/rg_stroke_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            
                            <RadioButton
                                android:id="@+id/rb_inside"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:checked="true"
                                android:text="Inside" />
                                
                            <RadioButton
                                android:id="@+id/rb_center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Center" />
                                
                            <RadioButton
                                android:id="@+id/rb_outside"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Outside" />
                        </RadioGroup>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Auto Adjust Padding"
                            android:textSize="14sp"
                            android:textColor="#333333" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_auto_adjust_padding"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_alpha" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_blur" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_start" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_progress" />

                </LinearLayout>
            </com.sonsation.library.ShadowLayout>

            <!-- Gradient Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌈 Gradient"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <com.sonsation.library.ShadowLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:background_color="#FFFFFF"
                app:background_radius="16dp"
                app:shadow_blur="10dp"
                app:shadow_offset_y="2dp"
                app:shadow_color="#11000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <include layout="@layout/item_slider" android:id="@+id/slider_gradient_x" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_gradient_y" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_gradient_angle" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"
                        android:background="#E0E0E0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stroke Gradient"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#666666"
                        android:layout_marginBottom="8dp"
                        android:layout_marginStart="16dp"/>

                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_gradient_x" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_gradient_y" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_gradient_angle" />

                </LinearLayout>
            </com.sonsation.library.ShadowLayout>

            <!-- Misc Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️ Misc Settings"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <com.sonsation.library.ShadowLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:background_color="#FFFFFF"
                app:background_radius="16dp"
                app:shadow_blur="10dp"
                app:shadow_offset_y="2dp"
                app:shadow_color="#11000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Render Mode"
                            android:textSize="14sp"
                            android:textColor="#333333" />

                        <RadioGroup
                            android:id="@+id/rg_render_mode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <RadioButton
                                android:id="@+id/rb_render_default"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Default" />

                            <RadioButton
                                android:id="@+id/rb_render_bitmap"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:text="Bitmap Cache" />

                            <RadioButton
                                android:id="@+id/rb_render_hardware"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hardware Layer" />
                        </RadioGroup>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Blur Type"
                            android:textSize="14sp"
                            android:textColor="#333333" />

                        <RadioGroup
                            android:id="@+id/rg_blur_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <RadioButton
                                android:id="@+id/rb_blur_normal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:text="Normal" />

                            <RadioButton
                                android:id="@+id/rb_blur_solid"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Solid" />

                            <RadioButton
                                android:id="@+id/rb_blur_outer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Outer" />

                            <RadioButton
                                android:id="@+id/rb_blur_inner"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Inner" />
                        </RadioGroup>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Stroke Blur Type"
                            android:textSize="14sp"
                            android:textColor="#333333" />

                        <RadioGroup
                            android:id="@+id/rg_stroke_blur_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <RadioButton
                                android:id="@+id/rb_stroke_blur_normal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:text="Normal" />

                            <RadioButton
                                android:id="@+id/rb_stroke_blur_solid"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Solid" />

                            <RadioButton
                                android:id="@+id/rb_stroke_blur_outer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Outer" />

                            <RadioButton
                                android:id="@+id/rb_stroke_blur_inner"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Inner" />
                        </RadioGroup>
                    </LinearLayout>

                </LinearLayout>
            </com.sonsation.library.ShadowLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>