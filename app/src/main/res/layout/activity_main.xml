<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Sticky Top Preview Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/preview_container"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="#ffffff"
        android:elevation="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_theme_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:padding="8dp"
            android:background="?selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_month"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#666666" />

        <com.sonsation.library.ShadowLayout
            android:id="@+id/shadow_layout"
            android:layout_width="160dp"
            android:layout_height="160dp"
            app:background_color="#FFFFFF"
            app:background_radius="32dp"
            app:shadow_blur="15dp"
            app:shadow_offset_y="5dp"
            app:shadow_color="#33000000"
            app:shadow_render_mode="BITMAP_CACHE"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Shadow"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

        </com.sonsation.library.ShadowLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Controls Area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/preview_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Colors Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎨 Colors"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <com.sonsation.library.ShadowLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:background_color="#FFFFFF"
                app:background_radius="16dp"
                app:shadow_blur="10dp"
                app:shadow_offset_y="2dp"
                app:shadow_color="#11000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include layout="@layout/item_color_picker" android:id="@+id/color_bg" />
                    <include layout="@layout/item_color_picker" android:id="@+id/color_shadow" />
                    <include layout="@layout/item_color_picker" android:id="@+id/color_stroke" />

                </LinearLayout>
            </com.sonsation.library.ShadowLayout>

            <!-- Shadow Geometry Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📐 Shadow Geometry"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <com.sonsation.library.ShadowLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:background_color="#FFFFFF"
                app:background_radius="16dp"
                app:shadow_blur="10dp"
                app:shadow_offset_y="2dp"
                app:shadow_color="#11000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <include layout="@layout/item_slider" android:id="@+id/slider_shadow_x" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_shadow_y" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_shadow_radius" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_shadow_spread" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_shadow_bitmap_resolution" />

                </LinearLayout>
            </com.sonsation.library.ShadowLayout>

            <!-- Shape Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟦 Shape"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <com.sonsation.library.ShadowLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:background_color="#FFFFFF"
                app:background_radius="16dp"
                app:shadow_blur="10dp"
                app:shadow_offset_y="2dp"
                app:shadow_color="#11000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <include layout="@layout/item_slider" android:id="@+id/slider_corner_radius" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_corner_smoothing" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_alpha" />

                </LinearLayout>
            </com.sonsation.library.ShadowLayout>

            <!-- Stroke Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🖌 Stroke"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <com.sonsation.library.ShadowLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:background_color="#FFFFFF"
                app:background_radius="16dp"
                app:shadow_blur="10dp"
                app:shadow_offset_y="2dp"
                app:shadow_color="#11000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_width" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_alpha" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_blur" />

                </LinearLayout>
            </com.sonsation.library.ShadowLayout>

            <!-- Gradient Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌈 Gradient"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <com.sonsation.library.ShadowLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:background_color="#FFFFFF"
                app:background_radius="16dp"
                app:shadow_blur="10dp"
                app:shadow_offset_y="2dp"
                app:shadow_color="#11000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <include layout="@layout/item_slider" android:id="@+id/slider_gradient_x" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_gradient_y" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_gradient_angle" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"
                        android:background="#E0E0E0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stroke Gradient"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#666666"
                        android:layout_marginBottom="8dp"
                        android:layout_marginStart="16dp"/>

                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_gradient_x" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_gradient_y" />
                    <include layout="@layout/item_slider" android:id="@+id/slider_stroke_gradient_angle" />

                </LinearLayout>
            </com.sonsation.library.ShadowLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>